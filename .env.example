# Notion
NOTION_API_KEY=
NOTION_REVIEWS_DATABASE_ID=
NOTION_AI_OS_PAGE_ID=

# Primary cloud models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CLAUDE_EXECUTION_MODEL=claude-haiku-4-5-20251001
GEMINI_API_KEY=

# OpenAI model routing
CODEX_MODEL_ID=gpt-5
ECONOMY_MODEL_ID=gpt-5-mini
NANO_MODEL_ID=gpt-5-nano

# Local executor defaults
# Keep the Ollama executor conservative on this hardware class.
OLLAMA_BASE_URL=
OLLAMA_MODEL=deepseek-coder:6.7b
OLLAMA_FALLBACK_MODEL=qwen2.5-coder:7b
OLLAMA_CONTEXT_LENGTH=2048
OLLAMA_NUM_PARALLEL=1
OLLAMA_FLASH_ATTENTION=false

# OS defaults
DEFAULT_PROJECT_ID=OS-V1
LOG_LEVEL=info
NOTION_MIRROR_POLL_MS=

# Ops / approval / escalation Telegram bot + chat
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Intake Telegram bot + chat
AIASSBOT_TELEGRAM_BOT_TOKEN=
AIASSBOT_TELEGRAM_CHAT_ID=
TELEGRAM_INTAKE_ENABLED=true
TELEGRAM_POLL_MS=

# Direct Codex terminal Telegram bot + chat
# Semi-auto machine broker:
# - read-only file/log inspection and safe verification commands auto-run
# - writes, approved commands, and git commits queue for /approve
CODEX_TERMINAL_TELEGRAM_BOT_TOKEN=
CODEX_TERMINAL_TELEGRAM_CHAT_ID=
TELEGRAM_TERMINAL_ENABLED=false
TELEGRAM_TERMINAL_ALLOWED_ROOTS=C:\AI.Ass,E:\Mobiledets
TELEGRAM_TERMINAL_BLOCK_PATHS=.git,node_modules,.next,dist,build
TELEGRAM_TERMINAL_ALLOWED_WRITE_EXTENSIONS=.js,.cjs,.mjs,.ts,.tsx,.json,.md,.css,.scss,.html,.txt,.yml,.yaml,.ps1,.env.example
TELEGRAM_TERMINAL_COMMAND_TIMEOUT_MS=120000
TELEGRAM_TERMINAL_MAX_FILE_BYTES=100000
TELEGRAM_TERMINAL_MAX_LIST_RESULTS=200

# Lightweight local-model Telegram bot for read-only log/task questions
LOCAL_TERMINAL_TELEGRAM_BOT_TOKEN=
LOCAL_TERMINAL_TELEGRAM_CHAT_ID=
TELEGRAM_LOCAL_TERMINAL_ENABLED=false
TELEGRAM_LOCAL_MODEL=deepseek-coder:6.7b
TELEGRAM_LOCAL_MODEL_TIMEOUT_MS=90000

# API usage dashboard sync
API_USAGE_SYNC_ENABLED=true
API_USAGE_SYNC_MS=300000
